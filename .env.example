# Enable Banking application ID (UUID, from Control Panel)
EB_APPLICATION_ID=

# Absolute path to the private RSA key (.pem) Enable Banking issued at registration
EB_PRIVATE_KEY_PATH=

# Redirect URL registered with Enable Banking — must match exactly
EB_REDIRECT_URI=https://your-domain.com/finance/callback

# Enable Banking production API base
EB_API_BASE=https://api.enablebanking.com

# Bank to link (ASPSP name + country code, per Enable Banking's ASPSP list)
EB_BANK_NAME=DKB
EB_BANK_COUNTRY=DE

# Bearer token guarding the HTTP API. Leave empty for loopback dev.
# Required when deploying to a host other than localhost. Generate with:
#   openssl rand -hex 32
PANEL_BEARER_TOKEN=

# Cron schedule for the in-process refresh scheduler (croner syntax).
# Default fires at 07:00, 12:00, 17:00, 22:00 local time — 4x/day, well under
# PSD2's background-fetch ceiling of 4/day per consent.
CRON_SCHEDULE=0 7,12,17,22 * * *

# IANA timezone the cron schedule fires in. Default Europe/Berlin.
# The operator's Mac POSTs its current TZ to /timezone whenever it changes,
# so this value will be overridden at runtime when the launchd agent runs.
TIMEZONE=Europe/Berlin
