# Enable Banking application ID (UUID, from Control Panel)
EB_APPLICATION_ID=

# Absolute path to the private RSA key (.pem) Enable Banking issued at registration
EB_PRIVATE_KEY_PATH=

# Redirect URL registered with Enable Banking — must match exactly
EB_REDIRECT_URI=https://your-domain.com/finance/callback

# Enable Banking production API base
EB_API_BASE=https://api.enablebanking.com

# Bank to link (ASPSP name + country code, per Enable Banking's ASPSP list)
EB_BANK_NAME=DKB
EB_BANK_COUNTRY=DE
